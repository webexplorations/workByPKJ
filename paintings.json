  {
    "id": "ardentMillsBuilding",
    "title": "ardentMillsBuilding",
    "date": "2024-08-24",
    "medium": "ink",
    "dimensions": "",
    "tags": [
      "urban-sketching"
    ],
    "description": "Although the perspective is off I really like this drawing. Notice the window on far right, third floor. It has a door in it. In the background are the silos that were painted by the Australian muralist Guido van Helten. In January 2026 the milling company pulled out and the building is currently vacant.",
    "image": "ardentMillsBuilding.png"
  },
  {
    "id": "autumnLeaf",
    "title": "autumnLeaf",
    "date": "2024-09-22",
    "medium": "watercolor",
    "dimensions": "",
    "tags": [
      "art-class",
      "showcase"
    ],
    "description": "The challenge for this art class was to paint fall leaves. I wanted to get the feel of the leaves falling off our maple tree outside my studio so I tilted the horizon and overlapped the leaves, each having a separate plane as it fell from the tree. I really like how the warm and cool colors work together as well as the shadows on the ground.",
    "image": "autumnLeaf.jpeg"
  },
